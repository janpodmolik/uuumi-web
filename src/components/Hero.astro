---
import WaitlistForm from './WaitlistForm.astro';
// Swap WaitlistForm for DownloadButton after launch:
// import DownloadButton from './DownloadButton.astro';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <h1>A screen time app your pet depends on.</h1>
      <p class="hero-subtitle">
        A virtual pet that lives on your screen time.
        Less scrolling means a happier pet. More scrolling?
        The wind blows them away.
      </p>
      <WaitlistForm />
      <!-- After launch, replace WaitlistForm with: -->
      <!-- <DownloadButton href="https://apps.apple.com/..." /> -->
      <p class="hero-note">Be the first to know when Uuumi launches.</p>
    </div>
    <div class="hero-mockup">
      <img src="/images/screenshots/hero-mockup.png" alt="Uuumi app screenshot" />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 5rem;
    background: linear-gradient(
      to bottom,
      var(--sky-1),
      var(--sky-2),
      var(--sky-3),
      var(--sky-4),
      var(--bg)
    );
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    max-width: 540px;
  }

  h1 {
    font-size: 3.75rem;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-note {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .hero-mockup {
    display: flex;
    justify-content: center;
  }

  .hero-mockup img {
    max-width: 340px;
    width: 100%;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-text {
      max-width: 100%;
    }

    h1 {
      font-size: 2.5rem;
    }

    .hero-mockup {
      order: -1;
    }

    .hero-mockup img {
      max-width: 260px;
    }
  }
</style>
