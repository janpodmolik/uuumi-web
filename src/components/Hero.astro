---
import WaitlistForm from './WaitlistForm.astro';
// Swap WaitlistForm for DownloadButton after launch:
// import DownloadButton from './DownloadButton.astro';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <h1>A screen time app your pet depends on.</h1>
      <p class="hero-subtitle">
        A virtual pet that lives on your screen time.
        Less scrolling means a happier pet. More scrolling?
        The wind blows them away.
      </p>
      <div class="essence-banner">
        <div class="essence-img-wrap floating">
          <div class="essence-glow"></div>
          <img class="essence-img" src={`${import.meta.env.BASE_URL}images/og_essence.png`} alt="Exclusive OG Essence" />
        </div>
        <div class="essence-text">
          <span class="essence-badge">Waitlist Exclusive</span>
          <p class="essence-title">Claim your <strong>OG Essence</strong></p>
          <p class="essence-desc">A one-time reward for early supporters. Once the waitlist closes, this essence is gone forever.</p>
        </div>
      </div>

      <WaitlistForm />
      <!-- After launch, replace WaitlistForm with: -->
      <!-- <DownloadButton href="https://apps.apple.com/..." /> -->
      <p class="hero-note">Be the first to know when Uuumi launches.</p>
    </div>
    <div class="hero-mockup">
      <img class="screenshot-light" src={`${import.meta.env.BASE_URL}images/screenshots/home-light.png`} alt="Uuumi app screenshot – light mode" />
      <img class="screenshot-dark" src={`${import.meta.env.BASE_URL}images/screenshots/home-dark.png`} alt="Uuumi app screenshot – dark mode" />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 5rem;
    background: linear-gradient(
      to bottom,
      var(--sky-1),
      var(--sky-2),
      var(--sky-3),
      var(--sky-4),
      var(--bg)
    );
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    max-width: 540px;
  }

  h1 {
    font-size: 3.75rem;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-note {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  /* Essence Banner */
  .essence-banner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(52, 199, 89, 0.12), rgba(0, 122, 255, 0.10));
    border: 1.5px solid rgba(52, 199, 89, 0.25);
    overflow: hidden;
    backdrop-filter: blur(12px);
  }

  .essence-img-wrap {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .essence-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 110px;
    background: radial-gradient(ellipse, rgba(173, 200, 240, 0.2), rgba(180, 160, 220, 0.1) 50%, transparent 70%);
    pointer-events: none;
  }

  .essence-img {
    width: auto;
    height: 88px;
    filter: drop-shadow(0 0 14px rgba(173, 200, 240, 0.6));
    position: relative;
    z-index: 1;
  }

  .essence-text {
    position: relative;
    z-index: 1;
  }

  .essence-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    margin-bottom: 0.4rem;
  }

  .essence-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
    line-height: 1.3;
  }

  .essence-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .hero-mockup {
    display: flex;
    justify-content: center;
  }

  .hero-mockup img {
    max-width: 340px;
    width: 100%;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-text {
      max-width: 100%;
    }

    h1 {
      font-size: 2.5rem;
    }

    .hero-mockup {
      order: -1;
    }

    .hero-mockup img {
      max-width: 260px;
    }

    .essence-banner {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
      padding: 1.25rem;
    }

    .essence-glow {
      left: 50%;
    }
  }
</style>
