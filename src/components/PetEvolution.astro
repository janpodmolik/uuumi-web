---
const base = import.meta.env.BASE_URL;

const plantPhases = [
  { img: 'evolutions/plant1', size: 72 },
  { img: 'evolutions/plant2', size: 80 },
];

const essences = [
  { name: 'Plant', id: 'plant' },
  { name: 'Troll', id: 'troll' },
  { name: 'Orc', id: 'orc' },
  { name: 'Clicker', id: 'clicker' },
  { name: 'Lion', id: 'lion' },
  { name: 'Stitches', id: 'stitches' },
  { name: 'Racoon', id: 'racoon' },
  { name: 'Moss', id: 'moss' },
  { name: 'Shroom', id: 'shroom' },
];
---

<section class="evolution" id="evolution">
  <div class="container">
    <h2 class="section-title reveal">Watch your Uuumi evolve</h2>
    <p class="section-subtitle reveal">
      Help your Uuumi survive its first day and reward it with an essence.
    </p>

    <!-- Essence carousel -->
    <div class="essence-carousel reveal">
      <div class="essence-track">
        {essences.map((ess) => (
          <div class="essence-item">
            <img src={`${base}images/essences/${ess.id}.png`} alt={`${ess.name} essence`} />
            <span class="essence-name">{ess.name}</span>
          </div>
        ))}
      </div>
    </div>

    <p class="evolution-heading reveal">
      Every day your Uuumi survives, it rewards you with an evolution.
    </p>

    <!-- Plant evolution showcase -->
    <div class="evolution-card reveal">
      <div class="evolution-phases">
        <img src={`${base}images/pets/blob-happy.png`} alt="Blob" class="phase-img" />
        <span class="symbol">+</span>
        <img src={`${base}images/essences/plant.png`} alt="Plant essence" class="essence-img" />
        <span class="symbol">&rarr;</span>
        {plantPhases.map((phase, index) => (
          <Fragment>
            <img src={`${base}images/${phase.img}.png`} alt={`Plant phase ${index + 1}`} class="phase-img" style={`--phase-size: ${phase.size}px;`} />
            {index < plantPhases.length - 1 && <span class="symbol">&rarr;</span>}
          </Fragment>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .evolution {
    padding: var(--section-padding);
    text-align: center;
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  /* Essence carousel — break out of .container padding */
  .essence-carousel {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin-bottom: 0;
    text-align: center;
  }

  .essence-carousel::-webkit-scrollbar {
    display: none;
  }

  .essence-track {
    display: inline-flex;
    gap: 1.25rem;
    padding: 0 2rem 0.5rem;
  }

  .essence-item {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    min-width: 80px;
  }

  .essence-item img {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  .essence-name {
    font-size: 0.85rem;
    font-weight: 600;
  }

  /* Evolution heading */
  .evolution-heading {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-top: 3.5rem;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  /* Plant evolution card */
  .evolution-card {
    background: var(--bg-subtle);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    display: inline-block;
  }

  .evolution-phases {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .symbol {
    color: var(--text-tertiary);
    font-size: 1.5rem;
    font-weight: 600;
  }

  .phase-img {
    width: var(--phase-size, 64px);
    height: var(--phase-size, 64px);
    object-fit: contain;
  }

  .essence-img {
    width: 44px;
    height: 44px;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 2rem;
    }

    .essence-track {
      padding: 0 1.25rem 0.5rem;
    }

    .evolution-card {
      padding: 2rem 1.5rem;
      max-width: calc(100vw - 2rem);
      box-sizing: border-box;
    }

    .evolution-phases {
      gap: 0.5rem;
    }

    .phase-img {
      --phase-size: 52px;
      width: var(--phase-size);
      height: var(--phase-size);
    }

    .essence-img {
      width: 36px;
      height: 36px;
    }

    .symbol {
      font-size: 1.25rem;
    }

    .essence-item img {
      width: 48px;
      height: 48px;
    }
  }

  @media (max-width: 420px) {
    .evolution-card {
      padding: 1.5rem 1rem;
    }

    .evolution-phases {
      gap: 0.35rem;
    }

    .phase-img {
      --phase-size: 40px;
      width: var(--phase-size);
      height: var(--phase-size);
    }

    .essence-img {
      width: 28px;
      height: 28px;
    }

    .symbol {
      font-size: 1rem;
    }
  }
</style>
