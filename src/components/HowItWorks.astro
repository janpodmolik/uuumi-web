---
const base = import.meta.env.BASE_URL;

const steps = [
  {
    number: '1',
    title: 'Pick your distractions',
    description: 'Choose which apps bring the wind. Social media, games, anything that pulls you in.',
  },
  {
    number: '2',
    title: 'Set the wind',
    description: 'How strong should it blow? Pick a preset — Gentle, Balanced, or Intense. You\'ll choose again each morning.',
  },
  {
    number: '3',
    title: 'Name it. Drop it. Grow together.',
    description: 'Your Uuumi lands on a floating island and reacts to everything you do. Less scrolling, calmer winds, a happier companion.',
  },
  {
    number: '4',
    title: 'Earn essences. Evolve.',
    description: 'Protect your Uuumi each day and earn essences. Feed them to unlock new forms. Every evolution is a milestone you built.',
  },
];
---

<section class="how-it-works" id="how-it-works">
  <div class="container">
    <div class="section-header reveal">
      <img class="on-phone-img floating" src={`${base}images/screenshots/on_phone.png`} alt="Uuumi on phone" />
      <h2 class="section-title">How it works</h2>
    </div>
    <div class="steps">
      {steps.map((step) => (
        <div class="step reveal">
          <div class="step-number">{step.number}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: var(--section-padding);
    background: linear-gradient(to bottom, var(--bg), var(--sky-4), var(--sky-3), var(--sky-4), var(--bg));
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 3.5rem;
  }

  .on-phone-img {
    width: 160px;
    height: auto;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3rem;
  }

  .step-number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--text-primary);
    color: var(--bg);
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .step h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .step p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .on-phone-img {
      width: 120px;
    }
  }
</style>
