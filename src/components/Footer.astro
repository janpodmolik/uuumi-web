---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <p>&copy; {year} Uuumi.</p>
    <div class="footer-links">
      <a href="https://www.youtube.com/@janpodmolik" target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="https://www.instagram.com/janpodmolik" target="_blank" rel="noopener noreferrer">Instagram</a>
      <a href="https://www.tiktok.com/@janpodmolik" target="_blank" rel="noopener noreferrer">TikTok</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Use</a>
      <button class="cookie-settings-btn" id="open-cookie-settings">Cookies</button>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--text-tertiary);
    transition: color 0.2s;
  }

  .footer-links a:hover,
  .cookie-settings-btn:hover {
    color: var(--text-primary);
  }

  .cookie-settings-btn {
    background: none;
    border: none;
    color: var(--text-tertiary);
    font-size: inherit;
    font-family: inherit;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
  }

  @media (max-width: 480px) {
    .footer-content {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>

<script is:inline>
  document.getElementById('open-cookie-settings')?.addEventListener('click', function() {
    if (window.__openCookieSettings) window.__openCookieSettings();
  });
</script>
