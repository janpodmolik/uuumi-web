---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <p>&copy; {year} Uuumi. Made in Prague.</p>
    <div class="footer-links">
      <a href="https://x.com/janpodmolik" target="_blank" rel="noopener noreferrer">X</a>
      <a href="https://tiktok.com/@janpodmolik" target="_blank" rel="noopener noreferrer">TikTok</a>
      <a href="https://instagram.com/janpodmolik" target="_blank" rel="noopener noreferrer">Instagram</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--text-tertiary);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--text-primary);
  }

  @media (max-width: 480px) {
    .footer-content {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
