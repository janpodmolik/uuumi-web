---
import WaitlistForm from './WaitlistForm.astro';
import EssenceBanner from './EssenceBanner.astro';
---

<section class="final-cta" id="waitlist">
  <div class="container cta-content reveal">
    <h2>Ready to meet your Uuumi?</h2>
    <p>Join the waitlist and be the first to give your screen time a face.</p>
    <EssenceBanner />
    <WaitlistForm />
  </div>
</section>

<style>
  .final-cta {
    padding: var(--section-padding);
    background: linear-gradient(to bottom, var(--bg), var(--sky-4), var(--sky-3));
  }

  .cta-content {
    max-width: 540px;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    h2 {
      font-size: 2rem;
    }
  }
</style>
