---
const base = import.meta.env.BASE_URL;
---

<div class="essence-banner">
  <div class="essence-img-wrap floating">
    <div class="essence-glow"></div>
    <img class="essence-img" src={`${base}images/og_essence.png`} alt="Exclusive OG Essence" />
  </div>
  <div class="essence-text">
    <span class="essence-badge">Waitlist Exclusive</span>
    <p class="essence-title">Claim your <strong>OG Essence</strong></p>
    <p class="essence-desc">
      A one-time reward for early supporters. Once the waitlist closes, this essence is gone forever.
      <a href="#evolution" class="essence-link">What's an essence?</a>
    </p>
  </div>
</div>

<style>
  .essence-banner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    margin: 0 auto 2rem;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(52, 199, 89, 0.12), rgba(0, 122, 255, 0.10));
    border: 1.5px solid rgba(52, 199, 89, 0.25);
    overflow: hidden;
    backdrop-filter: blur(12px);
  }

  .essence-img-wrap {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .essence-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 110px;
    background: radial-gradient(ellipse, rgba(173, 200, 240, 0.2), rgba(180, 160, 220, 0.1) 50%, transparent 70%);
    pointer-events: none;
  }

  .essence-img {
    width: auto;
    height: 88px;
    filter: drop-shadow(0 0 14px rgba(173, 200, 240, 0.6));
    position: relative;
    z-index: 1;
  }

  .essence-text {
    position: relative;
    z-index: 1;
  }

  .essence-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    margin-bottom: 0.4rem;
  }

  .essence-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
    line-height: 1.3;
  }

  .essence-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .essence-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .essence-link:hover {
    color: var(--accent-hover);
  }

  @media (max-width: 900px) {
    .essence-banner {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
      padding: 1.25rem;
    }

    .essence-glow {
      left: 50%;
    }
  }
</style>
