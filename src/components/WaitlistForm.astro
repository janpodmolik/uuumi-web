<form class="waitlist-form" id="waitlist-form">
  <div class="form-row">
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      autocomplete="email"
    />
    <button type="submit">Join the Waitlist</button>
  </div>
  <p class="form-message" id="form-message"></p>
  <div class="claim-code" id="claim-code">
    <p class="claim-label">Your OG essence claim code:</p>
    <span class="claim-value" id="claim-value">UUUBELIVER</span>
    <p class="claim-hint" id="claim-hint">Tap the code to copy it</p>
    <p class="claim-expiry">Valid for the first 3 months after release. We'll remind you before launch.</p>
  </div>
</form>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  function revealAllClaimCodes() {
    document.querySelectorAll<HTMLElement>('#claim-code').forEach((el) => el.classList.add('visible'));
    const heroNote = document.getElementById('hero-note');
    if (heroNote) heroNote.style.display = 'none';
  }

  document.querySelectorAll<HTMLFormElement>('#waitlist-form').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const message = form.querySelector('#form-message') as HTMLParagraphElement;
      const button = form.querySelector('button') as HTMLButtonElement;

      button.disabled = true;
      button.textContent = 'Joining...';

      try {
        const { error } = await supabase
          .from('waitlist')
          .insert({ email });

        if (error) {
          if (error.code === '23505') {
            message.textContent = "You're already on the list!";
            message.className = 'form-message success';
            revealAllClaimCodes();
          } else {
            throw error;
          }
        } else {
          message.textContent = "You're on the waitlist!";
          message.className = 'form-message success';
          revealAllClaimCodes();
          form.reset();
        }
      } catch {
        message.textContent = 'Something went wrong. Please try again.';
        message.className = 'form-message error';
      } finally {
        button.disabled = false;
        button.textContent = 'Join the Waitlist';
      }
    });
  });

  // Copy claim code on tap
  document.querySelectorAll<HTMLElement>('#claim-value').forEach((el) => {
    el.addEventListener('click', async () => {
      await navigator.clipboard.writeText(el.textContent ?? '');
      const hint = el.parentElement?.querySelector('#claim-hint');
      if (hint) {
        hint.textContent = 'Copied!';
        setTimeout(() => { hint.textContent = 'Tap the code to copy it'; }, 2000);
      }
    });
  });
</script>

<style>
  .waitlist-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .form-row {
    display: flex;
    gap: 0.5rem;
    max-width: 440px;
    width: 100%;
  }

  input[type='email'] {
    flex: 1;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 99px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--input-bg);
    color: var(--text-primary);
    transition: border-color 0.2s;
    outline: none;
  }

  input[type='email']:focus {
    border-color: var(--accent);
  }

  button {
    padding: 0.85rem 1.5rem;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 99px;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }

  button:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  button:active {
    transform: translateY(0);
  }

  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-message {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    min-height: 1.4em;
  }

  .form-message.success {
    color: var(--accent);
  }

  .form-message.error {
    color: var(--wind-high);
  }

  .claim-code {
    display: none;
    margin-top: 1.25rem;
    padding: 1.5rem 1.25rem 2rem;
    background: var(--bg-subtle);
    border-radius: 12px;
    text-align: center;
    max-width: 440px;
    box-shadow: 0 4px 24px rgba(100, 60, 160, 0.25), 0 0 48px rgba(120, 80, 180, 0.12);
  }

  .claim-code.visible {
    display: block;
    animation: fadeIn 0.4s ease;
  }

  .claim-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .claim-value {
    display: inline-block;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    background: var(--bg);
    border: 1.5px dashed var(--accent);
    border-radius: 8px;
    user-select: all;
    cursor: pointer;
    transition: background 0.2s;
  }

  .claim-value:active {
    background: var(--border);
  }

  .claim-hint {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    margin-top: 0.5rem;
  }

  .claim-expiry {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-top: 0.75rem;
    font-style: italic;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    .form-row {
      flex-direction: column;
    }

    button {
      width: 100%;
    }
  }
</style>
