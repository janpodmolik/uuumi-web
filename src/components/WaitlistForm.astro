<form class="waitlist-form" id="waitlist-form">
  <div class="form-row">
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      autocomplete="email"
    />
    <button type="submit">Join the Waitlist</button>
  </div>
  <input
    type="text"
    name="email_verification"
    autocomplete="off"
    tabindex="-1"
    aria-hidden="true"
    class="email-verify-field"
  />
  <label class="consent-label">
    <input type="checkbox" name="consent" required />
    <span>I agree to the <a href="/privacy" target="_blank">Privacy Policy</a></span>
  </label>
  <p class="form-message" id="form-message"></p>
</form>

<script>
  declare global {
    interface Window {
      dataLayer?: Record<string, unknown>[];
    }
  }

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  document.querySelectorAll<HTMLFormElement>('#waitlist-form').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const honeypot = formData.get('email_verification') as string;
      const message = form.querySelector('#form-message') as HTMLParagraphElement;
      const button = form.querySelector('button') as HTMLButtonElement;

      const consent = form.querySelector<HTMLInputElement>('input[name="consent"]');
      if (!consent?.checked) {
        message.textContent = 'Please agree to the Privacy Policy.';
        message.className = 'form-message error';
        return;
      }

      button.disabled = true;
      button.textContent = 'Joining...';

      try {
        const theme = document.documentElement.getAttribute('data-theme') || 'dark';

        const res = await fetch(`${SUPABASE_URL}/functions/v1/join-waitlist`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          },
          body: JSON.stringify({ email, theme, honeypot }),
        });

        if (res.status === 429) {
          message.textContent = 'Too many attempts. Please wait a moment.';
          message.className = 'form-message error';
          return;
        }

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Request failed');
        }

        if (data.duplicate) {
          message.textContent = "You're already on the list!";
          message.className = 'form-message success';
          window.dataLayer?.push({ event: 'waitlist_duplicate' });
        } else {
          message.textContent = "You're on the waitlist! Check your inbox.";
          message.className = 'form-message success';
          form.reset();
          window.dataLayer?.push({ event: 'waitlist_signup' });
        }
      } catch {
        message.textContent = 'Something went wrong. Please try again.';
        message.className = 'form-message error';
      } finally {
        button.disabled = false;
        button.textContent = 'Join the Waitlist';
      }
    });
  });
</script>

<style>
  .email-verify-field {
    position: absolute;
    clip: rect(0, 0, 0, 0);
    overflow: hidden;
    height: 1px;
    width: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    white-space: nowrap;
  }

  .waitlist-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .form-row {
    display: flex;
    gap: 0.5rem;
    max-width: 440px;
    width: 100%;
  }

  input[type='email'] {
    flex: 1;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 99px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--input-bg);
    color: var(--text-primary);
    transition: border-color 0.2s;
    outline: none;
  }

  input[type='email']:focus {
    border-color: var(--accent);
  }

  button {
    padding: 0.85rem 1.5rem;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 99px;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }

  button:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  button:active {
    transform: translateY(0);
  }

  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-message {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    min-height: 1.4em;
    padding: 0.6rem 1rem;
    border-radius: 10px;
    max-width: 440px;
    width: 100%;
  }

  .form-message:empty {
    padding: 0;
  }

  .form-message.success {
    color: var(--accent);
    background: rgba(52, 199, 89, 0.1);
  }

  .form-message.error {
    color: var(--wind-high);
    background: rgba(255, 69, 58, 0.1);
  }

  .consent-label {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-tertiary);
    max-width: 440px;
    width: 100%;
    cursor: pointer;
  }

  .consent-label input[type='checkbox'] {
    margin-top: 0.15rem;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .consent-label a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .consent-label a:hover {
    color: var(--accent-hover);
  }

  @media (max-width: 900px) {
    .waitlist-form {
      align-items: center;
    }
  }

  @media (max-width: 480px) {
    .form-row {
      flex-direction: column;
    }

    button {
      width: 100%;
    }
  }
</style>
